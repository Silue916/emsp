# Copie ce fichier en ".env" et renseigne les valeurs.
# Note: ce projet lit ces variables via l'environnement (PowerShell: $env:DJANGO_DEBUG="1", etc.).

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Recommandé en production (quand DJANGO_DEBUG=0)
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_PRELOAD=0
